---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/Container.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  lede?: string;
  ogImage?: string;
}

const { title, description, eyebrow, lede, ogImage } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Container size="narrow" class="py-16 md:py-24">
    <header class="mb-12 md:mb-16 text-center">
      {eyebrow && (
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim mb-4">{eyebrow}</p>
      )}
      <h1 class="text-4xl md:text-5xl font-black text-text">{title}</h1>
      {lede && (
        <p class="mt-6 text-lg text-text-muted max-w-2xl mx-auto">{lede}</p>
      )}
    </header>
    <article class="prose-flotilla">
      <slot />
    </article>
  </Container>
</BaseLayout>

<style is:global>
  .prose-flotilla {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .prose-flotilla > * + * {
    margin-top: 1.25em;
  }

  .prose-flotilla h2 {
    color: var(--color-text);
    font-size: 1.75rem;
    font-weight: 900;
    line-height: 1.2;
    margin-top: 3rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .prose-flotilla > h2:first-child {
    margin-top: 0;
  }

  .prose-flotilla h3 {
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .prose-flotilla h4 {
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .prose-flotilla p {
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .prose-flotilla strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .prose-flotilla em {
    font-style: italic;
  }

  .prose-flotilla a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 0.2em;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .prose-flotilla a:hover {
    color: var(--color-primary-soft);
    text-decoration-color: var(--color-primary);
  }

  .prose-flotilla ul,
  .prose-flotilla ol {
    padding-left: 1.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .prose-flotilla ul {
    list-style: disc;
  }

  .prose-flotilla ol {
    list-style: decimal;
  }

  .prose-flotilla li {
    margin-top: 0.5rem;
    line-height: 1.7;
  }

  .prose-flotilla li::marker {
    color: var(--color-primary);
  }

  .prose-flotilla hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .prose-flotilla blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .prose-flotilla code {
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
    color: var(--color-text);
  }
</style>
