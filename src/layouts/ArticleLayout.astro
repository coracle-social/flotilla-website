---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/Container.astro';

interface Props {
  title: string;
  description?: string;
  category?: 'basics' | 'advanced';
  readTime?: number;
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
  ogImage?: string;
}

const {
  title,
  description,
  category,
  readTime,
  prev = null,
  next = null,
  ogImage,
} = Astro.props;

const categoryLabel =
  category === 'basics' ? 'Basics' : category === 'advanced' ? 'Advanced' : null;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Container size="narrow" class="py-12 md:py-20">
    <header class="mb-10 md:mb-14">
      <a
        href="/articles"
        class="inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.2em] text-text-dim hover:text-text-muted transition-colors"
      >
        <span aria-hidden="true">&larr;</span>
        Knowledge Base
      </a>
      <h1 class="mt-5 text-4xl md:text-5xl font-black text-text leading-[1.1]">
        {title}
      </h1>
      {(categoryLabel || readTime) && (
        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-text-dim">
          {categoryLabel && (
            <span class="inline-flex items-center rounded-pill border border-border bg-surface px-3 py-1 font-mono text-xs uppercase tracking-[0.15em] text-text-muted">
              {categoryLabel}
            </span>
          )}
          {readTime && (
            <span class="font-mono text-xs uppercase tracking-[0.15em]">
              {readTime} min read
            </span>
          )}
        </div>
      )}
      {description && (
        <p class="mt-6 text-lg text-text-muted leading-relaxed">{description}</p>
      )}
    </header>

    <article class="prose-article">
      <slot />
    </article>

    {(prev || next) && (
      <nav
        aria-label="Article navigation"
        class="mt-16 md:mt-20 grid gap-4 sm:grid-cols-2 border-t border-border-soft pt-8"
      >
        {prev ? (
          <a
            href={`/articles/${prev.slug}`}
            class="group flex flex-col rounded-lg border border-border-soft bg-surface/50 p-5 hover:border-border hover:bg-surface transition-colors"
          >
            <span class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim">
              &larr; Previous
            </span>
            <span class="mt-2 font-bold text-text group-hover:text-primary-soft transition-colors">
              {prev.title}
            </span>
          </a>
        ) : (
          <span class="hidden sm:block" />
        )}
        {next ? (
          <a
            href={`/articles/${next.slug}`}
            class="group flex flex-col rounded-lg border border-border-soft bg-surface/50 p-5 sm:text-right hover:border-border hover:bg-surface transition-colors"
          >
            <span class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim">
              Next &rarr;
            </span>
            <span class="mt-2 font-bold text-text group-hover:text-primary-soft transition-colors">
              {next.title}
            </span>
          </a>
        ) : (
          <span class="hidden sm:block" />
        )}
      </nav>
    )}
  </Container>
</BaseLayout>

<style is:global>
  .prose-article {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .prose-article > * + * {
    margin-top: 1.25em;
  }

  .prose-article h1 {
    color: var(--color-text);
    font-size: 2.25rem;
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  /* The article body in markdown often starts with an h1 that duplicates the
     header title — hide it. */
  .prose-article > h1:first-child {
    display: none;
  }

  .prose-article h2 {
    color: var(--color-text);
    font-size: 1.75rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
  }

  .prose-article h3 {
    color: var(--color-text);
    font-size: 1.35rem;
    font-weight: 900;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .prose-article h4 {
    color: var(--color-text);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 1.75rem;
    margin-bottom: 0.25rem;
  }

  .prose-article p {
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  .prose-article strong {
    color: var(--color-text);
    font-weight: 700;
  }

  .prose-article em {
    font-style: italic;
  }

  .prose-article a {
    color: var(--color-text);
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 0.2em;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .prose-article a:hover {
    color: var(--color-primary-soft);
    text-decoration-color: var(--color-primary);
  }

  .prose-article ul,
  .prose-article ol {
    padding-left: 1.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .prose-article ul {
    list-style: disc;
  }

  .prose-article ol {
    list-style: decimal;
  }

  .prose-article li {
    margin-top: 0.5rem;
    line-height: 1.7;
  }

  .prose-article li::marker {
    color: var(--color-primary);
  }

  .prose-article hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  .prose-article blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1.75rem 0;
  }

  .prose-article img {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-soft);
    margin: 2rem auto;
    max-width: 100%;
  }

  /* Inline code */
  .prose-article :not(pre) > code {
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
    color: var(--color-primary-soft);
    font-family: var(--font-mono);
  }

  /* Fenced code blocks. Astro's default Shiki adds its own background color via
     inline style on the <pre>, so we override with !important to keep our look. */
  .prose-article pre {
    background: var(--color-surface) !important;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.1rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 1.75rem 0;
    -webkit-overflow-scrolling: touch;
  }

  .prose-article pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    color: inherit;
    font-size: inherit;
    font-family: inherit;
    white-space: pre;
  }

  /* Tables (the source markdown puts an "Images" reference table at the bottom
     of each article — make it small and unobtrusive). */
  .prose-article table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    margin: 1.5rem 0;
  }

  .prose-article th,
  .prose-article td {
    border: 1px solid var(--color-border-soft);
    padding: 0.5rem 0.75rem;
    text-align: left;
    vertical-align: top;
  }

  .prose-article th {
    color: var(--color-text);
    font-weight: 700;
    background: var(--color-surface);
  }
</style>
