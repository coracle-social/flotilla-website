---
const APP_URL = 'https://app.flotilla.social';
const DEMO_URL = 'https://cal.com/coracle.social';
const GITHUB_URL = 'https://github.com/coracle-social/flotilla';
const NOSTR_URL =
  'https://nostrhub.io/naddr1qvzqqqru7cpzp978pfzrv6n9xhq5tvenl9e74pklmskh4xw6vxxyp3j8qkke3cezqqy8yamnvumx2cmv3s7zmz';
const PODCAST_URL = 'https://fountain.fm/show/vnmoRQQ50siLFRE8k061';
const BLOG_URL = 'https://hodlbod.npub.pro/';

const year = new Date().getFullYear();

const externalAttrs = (href: string) =>
  /^https?:/.test(href) ? { target: '_blank', rel: 'noopener noreferrer' } : {};

const colA = [
  { label: 'Login', href: APP_URL },
  { label: 'Book a Demo', href: DEMO_URL },
  { label: 'Github', href: GITHUB_URL },
];
const colB = [
  { label: 'Nostr', href: NOSTR_URL },
  { label: 'Podcast', href: PODCAST_URL },
  { label: 'Blog', href: BLOG_URL },
];
---

<footer class="mt-24 border-t border-border-soft">
  <div class="mx-auto max-w-6xl px-5 py-12 md:px-8">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <a href="/" aria-label="Flotilla home">
        <img src="/logo.png" alt="Flotilla" class="h-7 w-auto" width="135" height="28" />
      </a>

      <div class="grid grid-cols-2 gap-x-12 gap-y-3 text-sm font-bold">
        <ul class="space-y-3">
          {colA.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-text-muted hover:text-text transition-colors"
                {...externalAttrs(l.href)}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
        <ul class="space-y-3">
          {colB.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-text-muted hover:text-text transition-colors"
                {...externalAttrs(l.href)}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-border-soft pt-6 text-xs text-text-dim md:flex-row md:items-center">
      <p>&copy; {year} Coracle Social</p>
      <div class="flex items-center gap-2">
        <a href="/terms" class="hover:text-text transition-colors">Terms of Service</a>
        <span aria-hidden="true">•</span>
        <a href="/privacy" class="hover:text-text transition-colors">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
