---
interface Props {
  class?: string;
  size?: 'narrow' | 'default' | 'wide';
}

const { class: className = '', size = 'default' } = Astro.props;

const sizes = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
};
---

<div class:list={['mx-auto px-5 md:px-8', sizes[size], className]}>
  <slot />
</div>
