---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Hero from '../components/home/Hero.astro';
import CommunityPlatform from '../components/home/CommunityPlatform.astro';
import FeatureGrid from '../components/home/FeatureGrid.astro';

const APP_URL = 'https://app.flotilla.social';
const NOSTR_URL = 'https://nostr.com/';
---

<BaseLayout title="Flotilla">
  <Hero />

  <CommunityPlatform />

  <FeatureGrid />

  <section class="relative py-20 md:py-28">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-5 md:px-8 lg:grid-cols-2">
      <div class="text-center lg:text-left">
        <h2 class="text-4xl font-black tracking-tight sm:text-5xl md:text-6xl">
          No Ads, No Spying
        </h2>
        <p class="mt-6 max-w-xl text-base text-text-muted sm:text-lg">
          <strong class="font-black text-white">Nostr is Freedom Tech.</strong>{' '}
          Cryptographic key pairs and an open protocol make it possible for you to own your data,
          and bring it anywhere.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3 lg:justify-start">
          <Button href={APP_URL}>Try Flotilla</Button>
          <Button href={NOSTR_URL} variant="secondary">Learn More</Button>
        </div>
      </div>

      <div class="relative">
        <img
          src="/images/f24oUUayMDxpXdqHcHpHYhFFhps.png"
          alt="Network of nodes illustration with a highlighted npub identity pill"
          class="mx-auto w-full max-w-lg"
          width="900"
          height="700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-28">
    <div class="mx-auto max-w-5xl px-5 md:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-text-muted">
          See it in action
        </p>
        <h2 class="mt-3 text-4xl font-black tracking-tight sm:text-5xl md:text-6xl">
          Nostr,<br />Your Way
        </h2>
        <p class="mx-auto mt-5 max-w-2xl text-base text-text-muted sm:text-lg">
          Watch our 4-minute video tour.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl">
        {/* TODO: real video URL */}
        <video
          class="video-player w-full"
          poster="/images/6sCyW16HLSqFcJfXEsrmNatgmK8.png"
          controls
          preload="none"
          playsinline
          src="https://coracle-media.us-southeast-1.linodeobjects.com/flotilla-tour.mov"
        >
          Your browser does not support embedded video.
        </video>
      </div>
    </div>
  </section>

  <section class="relative pb-24">
    <div class="mx-auto max-w-6xl px-5 md:px-8">
      <div class="cta-card relative overflow-hidden rounded-3xl px-6 py-16 text-center md:px-12 md:py-20">
        <h2 class="relative text-3xl font-black tracking-tight sm:text-4xl md:text-5xl">
          Discover a New Way to Connect
        </h2>
        <div class="relative mt-8 flex justify-center">
          <Button href={APP_URL} variant="inverted">Try Flotilla</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .video-player {
    border-radius: 22px;
    object-fit: cover;
    aspect-ratio: 16 / 9;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .cta-card {
    background: linear-gradient(135deg, #7161ff 0%, #5a4ee0 100%);
  }

  .cta-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(40% 60% at 20% 10%, rgba(255, 255, 255, 0.18), transparent 70%),
      radial-gradient(40% 60% at 80% 90%, rgba(0, 0, 0, 0.2), transparent 70%);
    pointer-events: none;
  }
</style>
