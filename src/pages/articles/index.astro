---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

const articles = await getCollection('articles');
const bySlug = new Map(articles.map((a) => [a.id, a] as const));

const sortByOrder = (a: (typeof articles)[number], b: (typeof articles)[number]) =>
  a.data.order - b.data.order;

// Pull out a 1-line summary from the body if no description is set.
function summarize(article: (typeof articles)[number]): string {
  const body = article.body ?? '';
  const stripped = body
    .replace(/^---[\s\S]*?---\s*/m, '')
    .replace(/^#\s.*$/m, '')
    .trim();
  const firstPara = stripped.split(/\n\s*\n/).find((chunk) => {
    const c = chunk.trim();
    return (
      c.length > 0 &&
      !c.startsWith('#') &&
      !c.startsWith('![') &&
      !c.startsWith('|') &&
      !c.startsWith('*Part of our guide') &&
      !c.startsWith('> ')
    );
  });
  if (!firstPara) return article.data.description ?? '';
  return firstPara
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function searchText(article: (typeof articles)[number]): string {
  return [article.data.title, article.data.description ?? '', article.id, summarize(article)]
    .join(' ')
    .toLowerCase();
}

// Organize the knowledge base by topic cluster, with the two pillar guides
// featured up top. Keep this list in sync when adding articles — anything not
// placed here falls into a "More" catch-all so it never disappears.
const CLUSTERS = [
  {
    id: 'start',
    title: 'Start here',
    featured: true,
    slugs: ['how-to-run-an-online-community', 'what-is-nostr'],
  },
  {
    id: 'getting-started',
    title: 'Getting started',
    slugs: [
      'what-is-flotilla',
      'getting-started',
      'installing-flotilla',
      'logging-in-to-flotilla',
      'setting-up-your-profile',
      'joining-a-space',
    ],
  },
  {
    id: 'nostr',
    title: 'Understanding Nostr',
    slugs: [
      'nostr-terms-explained',
      'understanding-your-nostr-identity',
      'backing-up-and-recovering-your-account',
    ],
  },
  {
    id: 'using',
    title: 'Using Flotilla',
    slugs: [
      'spaces-and-rooms-explained',
      'chatting-in-a-space',
      'direct-messages',
      'using-voice-and-video-calls',
      'finding-messages-and-recent-activity',
      'notifications-and-muting',
      'featured-content-and-library',
      'zaps-and-wallet',
      'customizing-how-flotilla-looks',
    ],
  },
  {
    id: 'running',
    title: 'Running a community',
    slugs: ['running-a-community', 'creating-a-space', 'managing-a-space', 'controlling-space-access'],
  },
  {
    id: 'hosting',
    title: 'Hosting your space',
    slugs: [
      'coracle-hosting',
      'managing-your-hosted-relay',
      'hosting-billing',
      'custom-domain',
      'self-hosting-a-space',
      'setting-up-media-storage-on-your-relay',
      'enabling-voice-and-video-calls-on-your-relay',
      'backing-up-and-upgrading-a-relay',
    ],
  },
  {
    id: 'privacy',
    title: 'Privacy, cost & account',
    slugs: ['is-flotilla-private', 'privacy-settings', 'deleting-your-account', 'is-flotilla-free'],
  },
  {
    id: 'help',
    title: 'Help & community',
    slugs: ['community-and-support'],
  },
];

const placed = new Set(CLUSTERS.flatMap((c) => c.slugs));
const sections = CLUSTERS.map((c) => ({
  ...c,
  items: c.slugs.map((s) => bySlug.get(s)).filter((a): a is (typeof articles)[number] => Boolean(a)),
})).filter((c) => c.items.length > 0);

const leftover = articles.filter((a) => !placed.has(a.id)).sort(sortByOrder);
if (leftover.length) {
  sections.push({ id: 'more', title: 'More', featured: false, slugs: [], items: leftover });
}
---

<BaseLayout
  title="Knowledge Base"
  description="Guides and answers for getting the most out of Flotilla — from joining your first space to running your own community."
>
  <Container size="default" class="py-16 md:py-24">
    <header class="mb-8 md:mb-10 max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim mb-4">
        Knowledge Base
      </p>
      <h1 class="text-4xl md:text-5xl font-black text-text">
        Guides &amp; resources
      </h1>
      <p class="mt-5 text-lg text-text-muted">
        Welcome to the Flotilla knowledge base. Start with a guide, or jump to the topic you need —
        from joining your first space to running your own community.
      </p>
    </header>

    {/* Revealed by the script below, so it's never a dead input without JS. */}
    <div class="mb-10 md:mb-12" data-search-wrap hidden>
      <label for="article-search" class="sr-only">Search articles</label>
      <div class="search-field relative">
        <svg
          class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-text-dim"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7" />
          <line x1="16.5" y1="16.5" x2="21" y2="21" />
        </svg>
        <input
          id="article-search"
          type="search"
          autocomplete="off"
          placeholder="Search articles…"
          class="w-full rounded-pill border border-border bg-surface py-3 pl-12 pr-4 text-text placeholder:text-text-dim"
          data-search-input
        />
      </div>
      <p class="sr-only" role="status" aria-live="polite" data-status></p>
    </div>

    {sections.map((section) => (
      <section class="mb-14 md:mb-20 last:mb-0" data-section>
        <div class="flex items-end justify-between mb-6 md:mb-8 border-b border-border-soft pb-3">
          <h2 class="text-2xl md:text-3xl font-black text-text">{section.title}</h2>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim" data-count>
            {section.items.length} {section.items.length === 1 ? 'article' : 'articles'}
          </span>
        </div>

        {section.featured ? (
          <div class="grid gap-5 md:grid-cols-2">
            {section.items.map((article) => (
              <a
                href={`/articles/${article.id}`}
                class="group relative flex flex-col overflow-hidden rounded-xl border border-border bg-surface p-7 hover:border-primary/50 transition-colors"
                data-card
                data-search={searchText(article)}
              >
                <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-transparent pointer-events-none" />
                <div class="relative flex flex-1 flex-col">
                  <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary-soft mb-3">
                    Guide
                  </p>
                  <h3 class="text-xl md:text-2xl font-black text-text leading-tight group-hover:text-primary-soft transition-colors">
                    {article.data.title}
                  </h3>
                  <p class="mt-3 text-text-muted leading-relaxed line-clamp-3 flex-1">
                    {summarize(article)}
                  </p>
                  <span class="mt-5 inline-flex items-center gap-2 font-bold text-text group-hover:text-primary-soft transition-colors">
                    Read guide
                    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
                  </span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="grid gap-5 sm:grid-cols-2">
            {section.items.map((article) => (
              <a
                href={`/articles/${article.id}`}
                class="group flex flex-col rounded-lg border border-border-soft bg-surface/40 p-6 hover:border-border hover:bg-surface transition-colors"
                data-card
                data-search={searchText(article)}
              >
                <h3 class="text-lg font-black text-text leading-snug group-hover:text-primary-soft transition-colors">
                  {article.data.title}
                </h3>
                <p class="mt-3 text-sm text-text-muted leading-relaxed line-clamp-3 flex-1">
                  {summarize(article)}
                </p>
                <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.18em] text-text-dim group-hover:text-primary-soft transition-colors">
                  Read more
                  <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
                </span>
              </a>
            ))}
          </div>
        )}
      </section>
    ))}

    <p class="py-16 text-center text-text-muted" data-empty hidden>
      No articles match <strong class="text-text" data-empty-term></strong>. Try a different term.
    </p>
  </Container>
</BaseLayout>

<script>
  const wrap = document.querySelector<HTMLElement>('[data-search-wrap]');
  const input = document.querySelector<HTMLInputElement>('[data-search-input]');
  const status = document.querySelector<HTMLElement>('[data-status]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');
  const emptyTerm = document.querySelector<HTMLElement>('[data-empty-term]');
  const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-section]'));

  if (wrap && input && status && empty && emptyTerm) {
    wrap.hidden = false;

    const plural = (n: number) => `${n} ${n === 1 ? 'article' : 'articles'}`;

    const apply = (raw: string) => {
      const term = raw.trim().toLowerCase();
      const matches = (el: HTMLElement) => !term || (el.dataset.search ?? '').includes(term);
      let total = 0;

      for (const section of sections) {
        let shown = 0;
        for (const card of section.querySelectorAll<HTMLElement>('[data-card]')) {
          const hit = matches(card);
          card.hidden = !hit;
          if (hit) shown += 1;
        }
        section.hidden = shown === 0;
        const count = section.querySelector<HTMLElement>('[data-count]');
        if (count) count.textContent = plural(shown);
        total += shown;
      }

      empty.hidden = total > 0;
      emptyTerm.textContent = `“${raw.trim()}”`;
      status.textContent = term ? `${plural(total)} matching “${raw.trim()}”` : '';
    };

    input.addEventListener('input', () => apply(input.value));
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && input.value) {
        input.value = '';
        apply('');
      }
    });

    if (input.value) apply(input.value);
  }
</script>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  [hidden] {
    display: none !important;
  }

  .search-field input:focus-visible {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(113, 97, 255, 0.25);
  }

  .search-field input::-webkit-search-cancel-button {
    -webkit-appearance: none;
    appearance: none;
  }
</style>
