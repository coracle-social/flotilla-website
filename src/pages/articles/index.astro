---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

const articles = await getCollection('articles');

const sortByOrder = (a: (typeof articles)[number], b: (typeof articles)[number]) =>
  a.data.order - b.data.order;

const featured = articles
  .filter((a) => !a.data.category)
  .sort(sortByOrder);

const basics = articles
  .filter((a) => a.data.category === 'basics')
  .sort(sortByOrder);

const advanced = articles
  .filter((a) => a.data.category === 'advanced')
  .sort(sortByOrder);

// Pull out a 1-line summary from the body if no description is set.
function summarize(article: (typeof articles)[number]): string {
  if (article.data.description) {
    // The seed description is the same generic site copy on every article,
    // which doesn't help here — try to do better from the body.
  }
  const body = article.body ?? '';
  // Strip leading "# Title", then grab first non-empty paragraph.
  const stripped = body
    .replace(/^---[\s\S]*?---\s*/m, '')
    .replace(/^#\s.*$/m, '')
    .trim();
  const firstPara = stripped.split(/\n\s*\n/).find((chunk) => {
    const c = chunk.trim();
    return c.length > 0 && !c.startsWith('#') && !c.startsWith('![') && !c.startsWith('|');
  });
  if (!firstPara) return article.data.description ?? '';
  // Strip markdown link syntax for the preview.
  return firstPara
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`]/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

const sections = [
  { id: 'basics', title: 'The Basics', items: basics },
  { id: 'advanced', title: 'Advanced', items: advanced },
];

const featuredArticle = featured[0];
const featuredSummary = featuredArticle ? summarize(featuredArticle) : '';
---

<BaseLayout
  title="Knowledge Base"
  description="Guides and answers for getting the most out of Flotilla — from joining your first space to running your own community."
>
  <Container size="default" class="py-16 md:py-24">
    <header class="mb-12 md:mb-16 max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim mb-4">
        Knowledge Base
      </p>
      <h1 class="text-4xl md:text-5xl font-black text-text">
        Guides &amp; resources
      </h1>
      <p class="mt-5 text-lg text-text-muted">
        Welcome to the Flotilla knowledge base. Find guides for using the platform, answers
        to common questions, and tips for running a healthy community.
      </p>
    </header>

    {featuredArticle && (
      <a
        href={`/articles/${featuredArticle.id}`}
        class="group relative block rounded-xl border border-border bg-surface p-7 md:p-10 mb-16 md:mb-20 overflow-hidden hover:border-primary/50 transition-colors"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-transparent pointer-events-none" />
        <div class="relative flex flex-col md:flex-row md:items-center md:gap-10">
          <div class="flex-1">
            <p class="font-mono text-xs uppercase tracking-[0.2em] text-primary-soft mb-3">
              Start here
            </p>
            <h2 class="text-2xl md:text-3xl font-black text-text leading-tight">
              {featuredArticle.data.title}
            </h2>
            <p class="mt-4 text-text-muted leading-relaxed line-clamp-3">
              {featuredSummary}
            </p>
          </div>
          <div class="mt-6 md:mt-0 md:flex-shrink-0">
            <span class="inline-flex items-center gap-2 font-bold text-text group-hover:text-primary-soft transition-colors">
              Read article
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </span>
          </div>
        </div>
      </a>
    )}

    {sections.map((section) => (
      <section class="mb-14 md:mb-20 last:mb-0">
        <div class="flex items-end justify-between mb-6 md:mb-8 border-b border-border-soft pb-3">
          <h2 class="text-2xl md:text-3xl font-black text-text">{section.title}</h2>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-text-dim">
            {section.items.length} {section.items.length === 1 ? 'article' : 'articles'}
          </span>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-2">
          {section.items.map((article) => (
            <a
              href={`/articles/${article.id}`}
              class="group flex flex-col rounded-lg border border-border-soft bg-surface/40 p-6 hover:border-border hover:bg-surface transition-colors"
            >
              <h3 class="text-lg font-black text-text leading-snug group-hover:text-primary-soft transition-colors">
                {article.data.title}
              </h3>
              <p class="mt-3 text-sm text-text-muted leading-relaxed line-clamp-3 flex-1">
                {summarize(article)}
              </p>
              <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs uppercase tracking-[0.18em] text-text-dim group-hover:text-primary-soft transition-colors">
                Read more
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </Container>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
